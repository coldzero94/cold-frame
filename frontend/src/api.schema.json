{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ColdframeApiContract",
  "$defs": {
    "Band": {
      "type": "string",
      "enum": [
        "evergreen",
        "budding",
        "fading"
      ]
    },
    "CreateFactResponse": {
      "description": "POST /api/fact \u2014 the created note (or null if blocked/empty) + dedup/secret-block report.",
      "properties": {
        "added": {
          "anyOf": [
            {
              "$ref": "#/$defs/NoteBrief"
            },
            {
              "type": "null"
            }
          ]
        },
        "deduped": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "blocked": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "added",
        "deduped",
        "blocked"
      ],
      "type": "object"
    },
    "Edge": {
      "properties": {
        "src": {
          "type": "string"
        },
        "dst": {
          "type": "string"
        },
        "relation": {
          "type": "string"
        }
      },
      "required": [
        "src",
        "dst",
        "relation"
      ],
      "type": "object"
    },
    "FactDetail": {
      "properties": {
        "id": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "memory_type": {
          "$ref": "#/$defs/MemoryType"
        },
        "status": {
          "$ref": "#/$defs/Status"
        },
        "confidence": {
          "type": "number"
        },
        "strength": {
          "$ref": "#/$defs/Strength"
        },
        "sources": {
          "items": {
            "$ref": "#/$defs/Source"
          },
          "type": "array"
        },
        "valid_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "edges": {
          "items": {
            "$ref": "#/$defs/Edge"
          },
          "type": "array"
        },
        "accesses": {
          "items": {
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "id",
        "content",
        "memory_type",
        "status",
        "confidence",
        "strength",
        "sources",
        "valid_at",
        "edges",
        "accesses"
      ],
      "type": "object"
    },
    "FactHistoryResponse": {
      "properties": {
        "versions": {
          "items": {
            "$ref": "#/$defs/HistoryVersion"
          },
          "type": "array"
        }
      },
      "required": [
        "versions"
      ],
      "type": "object"
    },
    "FieldNote": {
      "properties": {
        "id": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "type": {
          "$ref": "#/$defs/MemoryType"
        },
        "s": {
          "type": "number"
        },
        "band": {
          "$ref": "#/$defs/Band"
        },
        "atRisk": {
          "type": "boolean"
        },
        "imminent": {
          "type": "boolean"
        },
        "importance": {
          "type": "number"
        },
        "access": {
          "type": "integer"
        },
        "pinned": {
          "type": "boolean"
        },
        "ageDays": {
          "type": "integer"
        }
      },
      "required": [
        "id",
        "content",
        "type",
        "s",
        "band",
        "atRisk",
        "imminent",
        "importance",
        "access",
        "pinned",
        "ageDays"
      ],
      "type": "object"
    },
    "HistoryVersion": {
      "properties": {
        "id": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "status": {
          "$ref": "#/$defs/Status"
        },
        "version": {
          "type": "integer"
        },
        "valid_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "invalid_at": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "id",
        "content",
        "status",
        "version",
        "valid_at",
        "invalid_at"
      ],
      "type": "object"
    },
    "MemoryFieldResponse": {
      "properties": {
        "notes": {
          "items": {
            "$ref": "#/$defs/FieldNote"
          },
          "type": "array"
        },
        "total": {
          "type": "integer"
        }
      },
      "required": [
        "notes",
        "total"
      ],
      "type": "object"
    },
    "MemoryType": {
      "type": "string",
      "enum": [
        "semantic",
        "episodic",
        "procedural"
      ]
    },
    "NoteBrief": {
      "properties": {
        "id": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "memory_type": {
          "$ref": "#/$defs/MemoryType"
        },
        "status": {
          "$ref": "#/$defs/Status"
        },
        "confidence": {
          "type": "number"
        },
        "strength": {
          "$ref": "#/$defs/Strength"
        }
      },
      "required": [
        "id",
        "content",
        "memory_type",
        "status",
        "confidence",
        "strength"
      ],
      "type": "object"
    },
    "NotesResponse": {
      "properties": {
        "notes": {
          "items": {
            "$ref": "#/$defs/NoteBrief"
          },
          "type": "array"
        },
        "total": {
          "type": "integer"
        }
      },
      "required": [
        "notes",
        "total"
      ],
      "type": "object"
    },
    "SearchHit": {
      "properties": {
        "id": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "memory_type": {
          "$ref": "#/$defs/MemoryType"
        },
        "status": {
          "$ref": "#/$defs/Status"
        },
        "confidence": {
          "type": "number"
        },
        "strength": {
          "$ref": "#/$defs/Strength"
        },
        "score": {
          "type": "number"
        },
        "signals": {
          "$ref": "#/$defs/Signals"
        }
      },
      "required": [
        "id",
        "content",
        "memory_type",
        "status",
        "confidence",
        "strength",
        "score",
        "signals"
      ],
      "type": "object"
    },
    "SearchResponse": {
      "properties": {
        "query": {
          "type": "string"
        },
        "hits": {
          "items": {
            "$ref": "#/$defs/SearchHit"
          },
          "type": "array"
        }
      },
      "required": [
        "query",
        "hits"
      ],
      "type": "object"
    },
    "Signals": {
      "properties": {
        "semantic": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "bm25": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "edge": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        },
        "rrf": {
          "type": "number"
        },
        "rerank": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ]
        }
      },
      "required": [
        "semantic",
        "bm25",
        "edge",
        "rrf",
        "rerank"
      ],
      "type": "object"
    },
    "Source": {
      "properties": {
        "kind": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "role": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ]
        },
        "observed_at": {
          "type": "string"
        }
      },
      "required": [
        "kind",
        "ref",
        "role",
        "observed_at"
      ],
      "type": "object"
    },
    "Status": {
      "type": "string",
      "enum": [
        "active",
        "archived",
        "deleted"
      ]
    },
    "Strength": {
      "properties": {
        "value": {
          "type": "number"
        },
        "band": {
          "$ref": "#/$defs/Band"
        },
        "at_risk": {
          "type": "boolean"
        },
        "imminent": {
          "type": "boolean"
        }
      },
      "required": [
        "value",
        "band",
        "at_risk",
        "imminent"
      ],
      "type": "object"
    },
    "TriageItem": {
      "properties": {
        "id": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "memory_type": {
          "$ref": "#/$defs/MemoryType"
        },
        "status": {
          "$ref": "#/$defs/Status"
        },
        "confidence": {
          "type": "number"
        },
        "strength": {
          "$ref": "#/$defs/Strength"
        },
        "reason": {
          "$ref": "#/$defs/TriageReason"
        },
        "candidates": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "impact": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "content",
        "memory_type",
        "status",
        "confidence",
        "strength",
        "reason",
        "candidates",
        "impact"
      ],
      "type": "object"
    },
    "TriageReason": {
      "type": "string",
      "enum": [
        "true_conflict",
        "ambiguous_merge",
        "low_confidence",
        "pin_adjacent_archive"
      ]
    },
    "TriageResolveResponse": {
      "description": "POST /api/triage/{id}/resolve \u2014 acknowledgement of a triage action.",
      "properties": {
        "ok": {
          "type": "boolean"
        }
      },
      "required": [
        "ok"
      ],
      "type": "object"
    },
    "TriageResponse": {
      "properties": {
        "items": {
          "items": {
            "$ref": "#/$defs/TriageItem"
          },
          "type": "array"
        }
      },
      "required": [
        "items"
      ],
      "type": "object"
    }
  }
}
